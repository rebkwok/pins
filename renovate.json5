{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    // https://docs.renovatebot.com/upgrade-best-practices/
    // Includes
    // - pinning GH actions to digests
    // - reporting on "abandoned" dependencies
    // - adding min release age for npm security updates
    "config:best-practices",
    // We don't want automated docker/docker-compose/Dockerfile updates
    "docker:disable",
    // Add the nice badges
    "mergeConfidence:all-badges"
  ],
  "labels": ["dependencies"],
  // update transitive deps by updating the entire lockfile
  // We run this on the same schedule; add a note for the reviewer to do the
  // default dependencies first to reduce the amount needed for review in the
  // full lockfile update
  "lockFileMaintenance": {
      "enabled": true, 
      "schedule": [
        "* 0-3 * * WED"
      ],
      "prBodyNotes": [":information_source: Before reviewing this PR, merge any prod/dev dependency PRs and rebase."]
  },
  // don't auto-update python-version, we want to manage python updates ourselves
  "ignorePaths": [".python-version"],
  // Note package rules apply only to direct dependencies
  // group dependencies by dev/prod, cooldown 7 days, run early Wed mornings
  // rangeStrategy: bumps the range even if the new version satisfies the existing range. Means that
  // we get updates whenever they happen (with respect to the cooldown)
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["js"],
      "groupName": "js dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "addLabels": ["js"],
      "groupName": "js prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    // pep621 covers pyproject.toml and uv.lock files
    // https://docs.renovatebot.com/modules/manager/pep621/
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups", "tool.uv.dev-dependencies"],
      "addLabels": ["python"],
      "groupName": "python dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "project.optional-dependencies", "tool.uv.sources"],
      "addLabels": ["python"],
      "groupName": "python prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"],
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    // Pin a specific dependency to an upper allowed version
    // Otherwise renovate will use the general "bump" strategy to change the upper limit in pyproject.toml
    // and will bump it anyway
    // {
    //   "matchManagers": ["pep621"],
    //   "matchDepNames": ["reportlab"],
    //   "allowedVersions": "<=4.4.8"
    // },
  ],
  // Include vulnerability alerts; this uses dependabot and requires that depenency graph and
  // dependabot alerts are enabled in the repo
  // https://docs.renovatebot.com/configuration-options/#vulnerabilityalerts
  "vulnerabilityAlerts": {
    "addLabels": ["security"]
  }
}
