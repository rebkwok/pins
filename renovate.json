{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:disable",
    "mergeConfidence:all-badges"
  ],
  "labels": ["dependencies"],
  "lockFileMaintenance": {
      "enabled": true, 
      "schedule": [
        "* 0-3 * * WED"
      ]
  },
  "ignorePaths": [".python-version"],
  "bumpVersion": ["major", "minor", "patch", "prerelease"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["js"],
      "groupName": "js dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "addLabels": ["js"],
      "groupName": "js prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups", "tool.uv.dev-dependencies"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "addLabels": ["python"],
      "groupName": "python dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "project.optional-dependencies", "tool.uv.sources"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "addLabels": ["python"],
      "groupName": "python prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"],
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "addLabels": ["security"]
  }
}
