{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:disable",
    "mergeConfidence:all-badges"
  ],
  "labels": ["dependencies"],
  "lockFileMaintenance": {
      "enabled": true, 
      "schedule": [
        "* 0-3 * * WED"
      ],
      // update transitive deps by updating the entire lockfile
      "prBodyNotes": [":information_source: Before reviewing this PR, merge any prod/dev dependency PRs and rebase."]
  },
  "ignorePaths": [".python-version"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["js"],
      "groupName": "js dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "addLabels": ["js"],
      "groupName": "js prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups", "tool.uv.dev-dependencies"],
      "addLabels": ["python"],
      "groupName": "python dev dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "project.optional-dependencies", "tool.uv.sources"],
      "addLabels": ["python"],
      "groupName": "python prod dependencies",
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"],
      "minimumReleaseAge": "7 days",
      "schedule": [
        "* 0-3 * * WED"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "addLabels": ["security"]
  }
}
